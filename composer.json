{
    "name": "hiblaphp/cache",
    "description": "Promise based cache implementation based on PSR16 cache interface",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hibla\\Cache\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Reymart A. Calicdan",
            "email": "reymart.calicdan06@gmail.com"
        }
    ],
    "minimum-stability": "alpha",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "hiblaphp/event-loop": "^1.0",
        "hiblaphp/promise": "^1.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "laravel/pint": "^1.25"
    },
    "scripts": {
        "test": "./vendor/bin/pest",
        "format": "./vendor/bin/pint",
        "format-test": "./vendor/bin/pint --test",
        "analyze": "./vendor/bin/phpstan analyse"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
